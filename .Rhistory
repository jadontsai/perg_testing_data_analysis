df <- read_csv("perg_scores.csv")
install.packages("readr")
library(tidyverse)
df_clean <- df %>%
rename(
name = `Name/nickname:`,
feedback = `Feedback?`,
total_distance = `Total distance:`,
average_power = `Average power:`
) %>%
mutate(
feedback = case_when(
str_detect(feedback, regex("no", ignore_case = TRUE)) ~ "No feedback",
str_detect(feedback, regex("feed", ignore_case = TRUE)) ~ "Feedback",
TRUE ~ feedback
)
)
install.packages("broom")
install.packages("tidyverse")
library(tidyverse)
write_csv(summary_results, "output.csv")
summary_results <- paired_df %>%
group_by(metric) %>%
summarise(
n_pairs = n(),
mean_feedback = mean(`Feedback`, na.rm = TRUE),
mean_no_feedback = mean(`No feedback`, na.rm = TRUE),
mean_difference = mean(`Feedback` - `No feedback`, na.rm = TRUE),
.groups = "drop"
) %>%
left_join(ttest_results, by = c("metric", "n_pairs"))
print(summary_results)
write_csv(summary_results, "output.csv")
