install.packages("ggplot2")
library(ggplot2)
df_long <- read_csv("perg_scores.csv") |>
clean_names() |>
pivot_longer(
cols = starts_with("x") & ends_with("seconds"),
names_to = "time",
values_to = "score"
) |>
mutate(
time = str_remove(time, "^x"),
time = str_remove(time, "_seconds$"),
time = as.numeric(time)
)
